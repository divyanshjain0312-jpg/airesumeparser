# --- LLM API keys (fill the ones you'll use) ---
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Ollama (local, optional) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# --- YouTube Data API v3 (for course recommendations on the Skill Gap page) ---
# Get a key: https://console.cloud.google.com → enable "YouTube Data API v3" → Credentials → API key
# Leave blank to disable courses (skill gaps still work, just without videos).
YOUTUBE_API_KEY=your_youtube_key_here

# --- Model defaults ---
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Paths ---
UPLOAD_DIR=./uploads
VECTOR_DB_DIR=./vector_db

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
